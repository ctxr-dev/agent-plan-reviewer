{
  "name": "@ctxr/agent-plan-reviewer",
  "version": "1.0.1",
  "description": "Read-only adversarial reviewer of a plan or design before it is confirmed. Verifies every claim against the actual source and hunts gaps, blind spots, edge cases, infeasibilities, intent divergence, and missed steps. Read-only; uses whatever capabilities the environment provides and never halts when one is missing or unhealthy.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctxr-dev/agent-plan-reviewer.git"
  },
  "homepage": "https://github.com/ctxr-dev/agent-plan-reviewer#readme",
  "bugs": {
    "url": "https://github.com/ctxr-dev/agent-plan-reviewer/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "package.json",
    "AGENT.md",
    "README.md",
    "LICENSE"
  ],
  "ctxr": {
    "type": "agent",
    "target": "folder"
  },
  "keywords": [
    "agent-skills",
    "agents-md",
    "codex",
    "claude-code",
    "ctxr",
    "agent",
    "ai"
  ],
  "scripts": {
    "validate": "npx @ctxr/kit validate",
    "lint": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "markdownlint-cli2": "^0.14.0"
  }
}
